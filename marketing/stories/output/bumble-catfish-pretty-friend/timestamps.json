[
  {
    "timestamp": [
      0.03096875,
      2.37096875
    ],
    "text": " This is Dating Horror Story, Episode 5.",
    "speaker": null
  },
  {
    "timestamp": [
      2.7909687499999998,
      4.29096875
    ],
    "text": " So I matched with this girl on Bumble.",
    "speaker": null
  },
  {
    "timestamp": [
      4.770968750000001,
      5.83096875
    ],
    "text": " We talked for a week.",
    "speaker": null
  },
  {
    "timestamp": [
      6.230968750000001,
      6.83096875
    ],
    "text": " Seemed great.",
    "speaker": null
  },
  {
    "timestamp": [
      7.5709687500000005,
      9.43096875
    ],
    "text": " She asks if she can bring a friend to the date.",
    "speaker": null
  },
  {
    "timestamp": [
      9.87096875,
      11.29096875
    ],
    "text": " I say sure, no big deal.",
    "speaker": null
  },
  {
    "timestamp": [
      11.77096875,
      12.45096875
    ],
    "text": " I show up.",
    "speaker": null
  },
  {
    "timestamp": [
      12.810968749999999,
      15.970968749999999
    ],
    "text": " I walk over and introduce myself to who I think is my date.",
    "speaker": null
  },
  {
    "timestamp": [
      16.65096875,
      17.85096875
    ],
    "text": " The girl from her profile.",
    "speaker": null
  },
  {
    "timestamp": [
      18.41096875,
      20.67096875
    ],
    "text": " She gets confused, looks at me weird,",
    "speaker": null
  },
  {
    "timestamp": [
      21.03096875,
      23.23096875
    ],
    "text": " and then points behind her to her friend,",
    "speaker": null
  },
  {
    "timestamp": [
      23.23096875,
      25.13096875
    ],
    "text": " who's just casually waving at me.",
    "speaker": null
  },
  {
    "timestamp": [
      25.57096875,
      28.45096875
    ],
    "text": " I'm very confused.\"",
    "speaker": null
  },
  {
    "timestamp": [
      28.718468750000003,
      31.398468750000003
    ],
    "text": " After a dizzying back and forth, I finally ask,",
    "speaker": null
  },
  {
    "timestamp": [
      31.778468750000002,
      33.05846875
    ],
    "text": " Is this a prank?",
    "speaker": null
  },
  {
    "timestamp": [
      33.578468750000006,
      35.27846875
    ],
    "text": " They get confused and annoyed.",
    "speaker": null
  },
  {
    "timestamp": [
      35.71846875,
      40.99846875
    ],
    "text": " So I pull out Bumble, show the girl I thought was my date her own face on someone else's profile.",
    "speaker": null
  },
  {
    "timestamp": [
      41.63846875,
      42.41846875
    ],
    "text": " She is pissed.",
    "speaker": null
  },
  {
    "timestamp": [
      42.978468750000005,
      45.838468750000004
    ],
    "text": " And that's when it finally clicked in the catfisher's brain",
    "speaker": null
  },
  {
    "timestamp": [
      45.838468750000004,
      51.118468750000005
    ],
    "text": " that bringing the person whose photos you stole to the date was maybe, maybe a bad idea.",
    "speaker": null
  },
  {
    "timestamp": [
      51.98909375,
      53.26909375
    ],
    "text": " They start arguing.",
    "speaker": null
  },
  {
    "timestamp": [
      53.26909375,
      54.98909375
    ],
    "text": " Catfisher plays victim.",
    "speaker": null
  },
  {
    "timestamp": [
      54.98909375,
      57.649093750000006
    ],
    "text": " The friend tries to make logical sense of it all.",
    "speaker": null
  },
  {
    "timestamp": [
      57.649093750000006,
      60.02909375
    ],
    "text": " I'm just sitting there, spinning a paper straw",
    "speaker": null
  },
  {
    "timestamp": [
      60.02909375,
      63.12909375
    ],
    "text": " like a fidget spinner, completely silent.",
    "speaker": null
  },
  {
    "timestamp": [
      63.12909375,
      65.62909375000001
    ],
    "text": " I quietly excused myself to the bathroom,",
    "speaker": null
  },
  {
    "timestamp": [
      65.62909375000001,
      69.30909375
    ],
    "text": " took my time, read some articles, took a poop,",
    "speaker": null
  },
  {
    "timestamp": [
      69.84284375,
      70.32284375
    ],
    "text": " Why not?",
    "speaker": null
  },
  {
    "timestamp": [
      71.02284375,
      76.48284375
    ],
    "text": " When I came back, the pretty friend was still there to apologize on behalf of her disaster of a friend.",
    "speaker": null
  },
  {
    "timestamp": [
      76.98284375,
      78.68284375
    ],
    "text": " I figured, what the heck?",
    "speaker": null
  },
  {
    "timestamp": [
      79.14284375,
      81.30284375
    ],
    "text": " I asked if she wanted to grab a real date.",
    "speaker": null
  },
  {
    "timestamp": [
      81.92284375,
      84.70284375
    ],
    "text": " She said I seemed like a great guy, but she has a boyfriend.",
    "speaker": null
  },
  {
    "timestamp": [
      85.36284375,
      86.22284375
    ],
    "text": " We parted ways.",
    "speaker": null
  },
  {
    "timestamp": [
      86.70284375,
      88.40284375
    ],
    "text": " I went and bought myself sushi.",
    "speaker": null
  },
  {
    "timestamp": [
      89.18284375,
      90.50284375
    ],
    "text": " Reparations for the chaos.",
    "speaker": null
  },
  {
    "timestamp": [
      90.98284375,
      92.02284374999999
    ],
    "text": " Don't catfish.",
    "speaker": null
  },
  {
    "timestamp": [
      92.52284374999999,
      93.60284375
    ],
    "text": " It never works out.",
    "speaker": null
  }
]