  {
    "timestamp": [
      37.63784375,
      38.41784375
    ],
    "text": " No joke.",
    "speaker": null
  },
  {
    "timestamp": [
      38.95784375,
      40.89784375
    ],
    "text": " She goes, don't worry.",
