[
  {
    "timestamp": [
      0.03096875,
      2.81096875
    ],
    "text": " This is Dating Horror Story Episode 4.",
    "speaker": null
  },
  {
    "timestamp": [
      3.47096875,
      5.510968750000001
    ],
    "text": " So, I was in a five-year relationship.",
    "speaker": null
  },
  {
    "timestamp": [
      6.390968750000001,
      7.67096875
    ],
    "text": " It ended earlier this year.",
    "speaker": null
  },
  {
    "timestamp": [
      7.95096875,
      10.17096875
    ],
    "text": " I'd been single, just rebuilding myself.",
    "speaker": null
  },
  {
    "timestamp": [
      10.730968749999999,
      11.13096875
    ],
    "text": " Halloween.",
    "speaker": null
  },
  {
    "timestamp": [
      11.91096875,
      12.570968749999999
    ],
    "text": " Friday night.",
    "speaker": null
  },
  {
    "timestamp": [
      13.09096875,
      13.79096875
    ],
    "text": " No plans.",
    "speaker": null
  },
  {
    "timestamp": [
      14.29096875,
      18.39096875
    ],
    "text": " I was lonely and bored, so I downloaded Hinge for the first time ever.",
    "speaker": null
  },
  {
    "timestamp": [
      18.97096875,
      21.25096875
    ],
    "text": " Within one day, I had over a hundred likes.",
    "speaker": null
  },
  {
    "timestamp": [
      22.05096875,
      22.610968749999998
    ],
    "text": " Overwhelming.",
    "speaker": null
  },
  {
    "timestamp": [
      23.13096875,
      25.05096875
    ],
    "text": " A few guys asked me out within two days.",
    "speaker": null
  },
  {
    "timestamp": [
      25.59096875,
      28.75096875
    ],
    "text": " One of them seemed actually attractive.",
    "speaker": null
  },
  {
    "timestamp": [
      29.54534375,
      31.02534375
    ],
    "text": " And he lived in my town.",
    "speaker": null
  },
  {
    "timestamp": [
      31.645343750000002,
      33.44534375
    ],
    "text": " So I said yes.",
    "speaker": null
  },
  {
    "timestamp": [
      33.96534375,
      34.28534375
    ],
    "text": " Date.",
    "speaker": null
  },
  {
    "timestamp": [
      34.82534375,
      35.80534375
    ],
    "text": " The very next day.",
    "speaker": null
  },
  {
    "timestamp": [
      36.30534375,
      39.44534375
    ],
    "text": " Red flag number one, he insisted on picking me up.",
    "speaker": null
  },
  {
    "timestamp": [
      39.90534375,
      41.34534375
    ],
    "text": " Like really insisted.",
    "speaker": null
  },
  {
    "timestamp": [
      41.62534375,
      43.22534375
    ],
    "text": " Quote, I'm a true gentleman.",
    "speaker": null
  },
  {
    "timestamp": [
      43.80534375,
      45.58534375
    ],
    "text": " I told him I'd just meet him there.",
    "speaker": null
  },
  {
    "timestamp": [
      45.76534375,
      46.50534375
    ],
    "text": " He doubled down.",
    "speaker": null
  },
  {
    "timestamp": [
      46.98534375,
      48.20534375
    ],
    "text": " I doubled down harder.",
    "speaker": null
  },
  {
    "timestamp": [
      48.82534375,
      49.54534375
    ],
    "text": " He gave up.",
    "speaker": null
  },
  {
    "timestamp": [
      49.99784375,
      55.95784375
    ],
    "text": " I get to the restaurant. Nice place. His pick. On the pricey side. He's already there.",
    "speaker": null
  },
  {
    "timestamp": [
      56.49784375,
      63.93784375
    ],
    "text": " He's already ordered drinks for both of us, before I even sat down. Already weird. But I roll with it.",
    "speaker": null
  },
  {
    "timestamp": [
      63.93784375,
      71.13784375
    ],
    "text": " We talk about jobs. What we want in life. He gets all vulnerable. Says he wants real love.",
    "speaker": null
  },
  {
    "timestamp": [
      71.77784375,
      75.11784375
    ],
    "text": " Says he feels something different about me. Versus other women.",
    "speaker": null
  },
  {
    "timestamp": [
      75.78284375,
      85.34284375
    ],
    "text": " Skeptical? Of course. But I let it ride. An hour in, he orders another drink, plus two appetizers,",
    "speaker": null
  },
  {
    "timestamp": [
      86.04284375,
      91.58284375
    ],
    "text": " plus an entree. I just got my entree. He keeps pushing a second drink on me.",
    "speaker": null
  },
  {
    "timestamp": [
      91.58284375,
      98.36284375
    ],
    "text": " I don't drink that much. He drinks it himself. Then he says, and this is the line quote,",
    "speaker": null
  },
  {
    "timestamp": [
      99.40784375000001,
      101.50784375
    ],
    "text": " I had so much to drink.",
    "speaker": null
  },
  {
    "timestamp": [
      101.50784375,
      103.38784375000002
    ],
    "text": " I have to use the bathroom.",
    "speaker": null
  },
  {
    "timestamp": [
      103.38784375000002,
      106.24784375000002
    ],
    "text": " I'm sitting there, alone,",
    "speaker": null
  },
  {
    "timestamp": [
      106.24784375000002,
      107.78784375000001
    ],
    "text": " and the little voice in my head goes,",
    "speaker": null
  },
  {
    "timestamp": [
      107.78784375000001,
      110.28784375000001
    ],
    "text": " oh, oh no.",
    "speaker": null
  },
  {
    "timestamp": [
      110.28784375000001,
      113.30784375000002
    ],
    "text": " Five minutes, 10, 15.",
    "speaker": null
  },
  {
    "timestamp": [
      113.30784375000002,
      115.02784375000002
    ],
    "text": " The waitress comes by.",
    "speaker": null
  },
  {
    "timestamp": [
      115.02784375000002,
      117.38784375000002
    ],
    "text": " I'm holding back tears because I know",
    "speaker": null
  },
  {
    "timestamp": [
      117.39659375000001,
      119.89659375000001
    ],
    "text": " I tell her I'm on a first date and I think he just left.",
    "speaker": null
  },
  {
    "timestamp": [
      120.29659375000001,
      121.17659375000001
    ],
    "text": " She gets the manager.",
    "speaker": null
  },
  {
    "timestamp": [
      121.77659375,
      123.03659375000001
    ],
    "text": " He left me with the bill.",
    "speaker": null
  },
  {
    "timestamp": [
      123.61659375,
      124.09659375000001
    ],
    "text": " He left.",
    "speaker": null
  },
  {
    "timestamp": [
      124.61659375,
      125.37659375000001
    ],
    "text": " On Halloween.",
    "speaker": null
  },
  {
    "timestamp": [
      126.41659375,
      131.05659375000002
    ],
    "text": " After ordering enough food for three people and giving me the whole true gentleman performance,",
    "speaker": null
  },
  {
    "timestamp": [
      131.59659375,
      132.99659375000002
    ],
    "text": " the manager felt so bad.",
    "speaker": null
  },
  {
    "timestamp": [
      133.75659375,
      135.65659375
    ],
    "text": " They split the check to just my entree.",
    "speaker": null
  },
  {
    "timestamp": [
      136.25659375,
      139.81659375
    ],
    "text": " So, that was my first date in six years.",
    "speaker": null
  },
  {
    "timestamp": [
      139.81659375,
      143.33659375000002
    ],
    "text": " I am never doing this again.",
    "speaker": null
  }
]