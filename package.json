{
  "name": "thumos",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc -p tsconfig.json --noEmit",
    "db:migrate": "node scripts/apply-db-migrations.mjs",
    "verify:live": "node scripts/verify-live-refactor.mjs",
    "ios:generate": "xcodegen generate",
    "ios:list": "xcodebuild -list -project Thumos.xcodeproj",
    "workers:dev": "pnpm --dir workers run dev",
    "workers:deploy": "pnpm --dir workers run deploy"
  },
  "devDependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@types/node": "^24.6.0",
    "dotenv": "^17.2.3",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "zod": "^4.1.11"
  }
}
